APP_ENV=development
APP_PORT=8000

DATABASE_URL=postgresql://budgetbasket:budgetbasket@postgres:5432/budgetbasket
POSTGRES_DB=budgetbasket
POSTGRES_USER=budgetbasket
POSTGRES_PASSWORD=budgetbasket

S3_ENDPOINT=http://seaweedfs:8333
S3_REGION=us-east-1
S3_ACCESS_KEY=budgetbasket
S3_SECRET_KEY=budgetbasket_secret
S3_BUCKET=budgetbasket-files
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:8333

MAX_UPLOAD_FILE_SIZE_MB=25
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/png,image/jpeg,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Внутренняя проверка файлов
FILE_GUARD_URL=http://file_guard:8080
FILE_GUARD_CONNECT_TIMEOUT_SECONDS=2
FILE_GUARD_READ_TIMEOUT_SECONDS=35
FILE_GUARD_MAX_FILE_SIZE_BYTES=26214400
FILE_GUARD_ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.xlsx,.docx
FILE_GUARD_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.openxmlformats-officedocument.wordprocessingml.document
FILE_GUARD_STRUCTURAL_VALIDATION_ENABLED=true
FILE_GUARD_ALLOW_LIBMAGIC_FALLBACK=true
FILE_GUARD_ANTIVIRUS_ENABLED=true
FILE_GUARD_REQUIRE_ANTIVIRUS=true
FILE_GUARD_ANTIVIRUS_TIMEOUT_SECONDS=10
FILE_GUARD_SCAN_TIMEOUT_SECONDS=30
FILE_GUARD_CLAMD_STREAM_CHUNK_BYTES=65536
FILE_GUARD_OFFICE_MAX_ENTRIES=200
FILE_GUARD_OFFICE_MAX_TOTAL_UNCOMPRESSED_BYTES=41943040
FILE_GUARD_OFFICE_MAX_ENTRY_UNCOMPRESSED_BYTES=12582912
FILE_GUARD_OFFICE_MAX_COMPRESSION_RATIO=120
FILE_GUARD_OFFICE_MAX_XML_SCAN_BYTES=1048576
FILE_GUARD_OFFICE_MAX_ENTRY_NAME_LENGTH=255
FILE_GUARD_UPLOAD_READ_CHUNK_BYTES=1048576
FILE_GUARD_IMAGE_MAX_WIDTH=12000
FILE_GUARD_IMAGE_MAX_HEIGHT=12000
FILE_GUARD_IMAGE_MAX_PIXELS=40000000
FILE_GUARD_CLAMAV_UPDATE_ON_START=true
FILE_GUARD_FRESHCLAM_ATTEMPTS=3

PGADMIN_DEFAULT_EMAIL=admin@budgetbasket.com
PGADMIN_DEFAULT_PASSWORD=admin
